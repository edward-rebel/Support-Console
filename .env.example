# ─────────────────────────────────────────────────────────────────────────────
# Molly & Stitch Support Console — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# Vars marked "(Phase N)" are not used until that build phase.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Railway-hosted). Used by db, api, worker.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Gmail OAuth (Phase 0) ────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# The refresh token is obtained via the in-app OAuth flow and stored ENCRYPTED in
# the `connections` table — it does NOT live here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# The Gmail mailbox this console manages (used to label the stored connection).
GMAIL_ACCOUNT=contact@mollyandstitch.us

# ── Sessions & encryption (Phase 0) ──────────────────────────────────────────
# Long random strings. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Exactly 32 bytes, hex-encoded (64 hex chars) — AES-256 key for encrypting
# stored OAuth tokens at rest. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Operator account (Phase 0) ───────────────────────────────────────────────
# Used ONCE by the seed script to create the single operator login.
OPERATOR_EMAIL=
OPERATOR_PASSWORD=

# ── URLs (Phase 0) ───────────────────────────────────────────────────────────
# APP_BASE_URL = the API origin (OAuth redirect is built from this).
# WEB_BASE_URL = the frontend origin (CORS + post-login redirect).
APP_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:5173

# ── Ingestion tuning (Phase 0) ───────────────────────────────────────────────
# How far back the one-time backfill reaches, and the incremental poll interval.
BACKFILL_MONTHS=6
SYNC_INTERVAL_MINUTES=5

# ── AI (Phase 1+) — not used in Phase 0 ──────────────────────────────────────
# ANTHROPIC_API_KEY=
# EMBEDDINGS_API_KEY=

# ── Shopify (Phase 4) — read scopes only, not used in Phase 0 ────────────────
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ADMIN_ACCESS_TOKEN=
