{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile --prod=false && pnpm --filter @ms/web build"
  },
  "deploy": {
    "startCommand": "pnpm db:migrate && pnpm db:seed && pnpm --filter @ms/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
