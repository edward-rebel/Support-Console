{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @ms/api build"
  },
  "deploy": {
    "startCommand": "pnpm db:migrate && pnpm db:seed && pnpm --filter @ms/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
