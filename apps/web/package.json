{
  "name": "@ms/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "serve -s dist -l ${PORT:-4173}",
